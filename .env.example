# ─── jeo-claw orchestration env (EXAMPLE — copy to .env, never commit real values) ───
# All real secrets are pulled at runtime from gcloud Secret Manager (see secrets/loader.ts).
# These vars are only references / non-secret config. Plaintext tokens MUST NOT live here.

# --- Shared LLM provider (identical for both runtimes → fair A/B comparison) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-codex
OPENAI_WIRE_API=responses
# OPENAI_API_KEY is injected by the secret loader, not set here.

# --- Workflow target repo ---
TARGET_REPO=akillness/jeo-claw
TARGET_BRANCH=main

# --- gcloud Secret Manager (Secret Manager use ONLY; no hosting at this stage) ---
GCLOUD_PROJECT=your-gcp-project-id
GCLOUD_SECRET_PREFIX=jeo-claw

# --- Discord (bot token injected by secret loader; these are non-secret IDs) ---
DISCORD_GUILD_ID=
DISCORD_REQUEST_CHANNEL_ID=
DISCORD_STATUS_CHANNEL_ID=
DISCORD_APPROVAL_CHANNEL_ID=
DISCORD_DASHBOARD_CHANNEL_ID=

# --- Glue / webhook server ---
GLUE_PORT=8787
GITHUB_WEBHOOK_PATH=/webhook/github
# GITHUB_WEBHOOK_SECRET + GITHUB_TOKEN injected by secret loader.

# --- Egress proxy (containers reach the internet ONLY through this allowlisted proxy) ---
EGRESS_PROXY_URL=http://egress-proxy:3128

# --- Autonomy / safety ---
AUTONOMY=supervised
# high-risk actions (merge/push) require Discord approval regardless of this value.

# --- A/B comparison ---
COMPARE_RUNS=5
