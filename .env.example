# ─── jeo-claw orchestration env (EXAMPLE — copy to .env, never commit real values) ───
# All real secrets are pulled at runtime from gcloud Secret Manager (see secrets/loader.ts).
# These vars are only references / non-secret config. Plaintext tokens MUST NOT live here.

# --- Shared LLM provider (identical for both runtimes → fair A/B comparison) ---
LLM_PROVIDER=openai-codex
LLM_MODEL=gpt-5-codex
OPENAI_WIRE_API=responses
# OAuth credentials (<prefix>-openai-codex-oauth, Codex auth.json 형식) are injected by Secret Manager. Plaintext tokens MUST NOT live here.

# --- Workflow target repo ---
TARGET_REPO=akillness/jeo-claw
TARGET_BRANCH=main

# --- gcloud Secret Manager (Secret Manager use ONLY; no hosting at this stage) ---
GCLOUD_PROJECT=your-gcp-project-id
GCLOUD_SECRET_PREFIX=jeo-claw

# Optional local/CI secret source override for container bring-up without gcloud ADC.
# Leave as gcloud for production. When using file mode, mount the JSON file into the container path below.
JEO_SECRET_SOURCE=gcloud
JEO_SECRETS_FILE=/run/secrets/jeo-claw-secrets.json

# --- Discord (bot token is injected by secret loader; IDs below are non-secret) ---
# Required for live bot start:
DISCORD_GUILD_ID=
DISCORD_REQUEST_CHANNEL_ID=
DISCORD_APPROVAL_CHANNEL_ID=
# Optional: set when non-admin/non-Manage-Guild users may approve high-risk actions.
DISCORD_APPROVER_ROLE_ID=
# Optional: override bootstrap-created channel names when IDs are omitted.
DISCORD_REQUEST_CHANNEL_NAME=jeo-request
DISCORD_APPROVAL_CHANNEL_NAME=jeo-approval
# Optional/dormant until status/dashboard posting is wired.
DISCORD_STATUS_CHANNEL_ID=
DISCORD_DASHBOARD_CHANNEL_ID=

# --- Glue / webhook server ---
GLUE_HOST_PORT=8787
GLUE_PORT=8787
GITHUB_WEBHOOK_PATH=/webhook/github
# GITHUB_WEBHOOK_SECRET + DISCORD_BOT_TOKEN + JEO_CONTROL_EVENT_SECRET are injected by the secret loader.
# Optional local/mock override for control-plane GitHub writes.
# Leave blank for production GitHub API.
GITHUB_API_BASE_URL=

# --- Egress proxy (containers reach the internet ONLY through this allowlisted proxy) ---
EGRESS_PROXY_URL=http://egress-proxy:3128

# --- Autonomy / safety ---
AUTONOMY=supervised
# high-risk actions (`pr.create` / `pr.merge`) require Discord approval regardless of this value.

# --- A/B comparison ---
COMPARE_RUNS=5
